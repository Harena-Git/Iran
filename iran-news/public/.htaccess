# Rewriting des URLs pour le routeur PHP

<IfModule mod_rewrite.c>
    # Activation du rewriting
    RewriteEngine On
    
    # Base de l'application (à adapter si application dans sous-dossier)
    RewriteBase /
    
    # Ne pas réécrire les fichiers statiques (CSS, JS, images, etc.)
    RewriteCond %{REQUEST_URI} \.(css|js|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|otf|eot)$ [NC]
    RewriteRule .* - [L]
    
    # Ne pas réécrire si la requête est pour un fichier existant
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule .* - [L]
    
    # Redirige toutes les autres requêtes vers index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Headers de sécurité
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>
